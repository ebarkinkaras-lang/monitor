{
  "name": "turkiye-monitor",
  "version": "1.5.0",
  "description": "TürkiyeMonitor — Standalone Cool-Retro Financial & Geopolitical Dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder -w"
  },
  "author": "TürkiyeMonitor",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "lightweight-charts": "^5.1.0"
  },
  "build": {
    "appId": "com.turkiyemonitor.app",
    "productName": "TurkiyeMonitor",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "directories": {
      "output": "release"
    }
  }
}
